Screen {
    layout: vertical;
    overflow: hidden;
}

/* ── Urgent ── */
#urgent {
    height: auto;
    max-height: 3;
}

/* ── Header ── */
#header {
    height: auto;
    max-height: 7;
}

/* ── Active Sessions (shrunk — scrollable panels need the space) ── */
#active-sessions {
    height: auto;
    max-height: 6;
}

#active-calls {
    height: auto;
    max-height: 8;
}

/* ── History row: Call History + Session History side-by-side ── */
#history-row {
    layout: horizontal;
    height: 2fr;
    min-height: 8;
}

#call-history {
    width: 1fr;
    height: 100%;
    border: solid green;
    border-title-color: white;
    border-title-style: bold;
}

#call-history:focus {
    border: tall $accent;
}

#session-history {
    width: 1fr;
    height: 1fr;
    min-height: 8;
    border: solid dodgerblue;
    border-title-color: white;
    border-title-style: bold;
}

#session-history:focus {
    border: tall $accent;
}

/* ── Feed row ── */
#feed-row {
    layout: horizontal;
    height: 1fr;
    min-height: 6;
}

/* ── Tool Call Feed (scrollable DataTable) ── */
#tool-feed {
    width: 3fr;
    border: solid magenta;
    border-title-color: white;
    border-title-style: bold;
}

#tool-feed:focus {
    border: tall $accent;
}

/* ── Stats column (Tool Frequency + Skills) ── */
#stats-col {
    width: 1fr;
    height: auto;
}

#tool-freq {
    height: auto;
    max-height: 16;
}

#skills {
    height: auto;
    max-height: 12;
}

/* ── Passive Drain (shrunk) ── */
#drain {
    height: auto;
    max-height: 10;
}

/* ── Drill-down screen ── */
#drilldown-header {
    height: auto;
    max-height: 2;
    padding: 0 1;
}

#drilldown-table {
    height: 1fr;
    border: solid dodgerblue;
}

/* ── Usage metrics screen ── */
#metrics-header {
    height: auto;
    max-height: 2;
    padding: 0 1;
}

#metrics-table {
    height: 1fr;
    border: solid cyan;
}

#metrics-summary {
    height: auto;
    max-height: 3;
    padding: 0 1;
}

/* ── DataTable styling ── */
DataTable {
    scrollbar-size: 1 1;
}

DataTable > .datatable--header {
    text-style: bold;
}
