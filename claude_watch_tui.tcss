Screen {
    layout: vertical;
}

/* ── Nav Bar ── */
#nav-bar {
    height: 3;
    dock: top;
    background: $surface;
    padding: 0 1;
}

#nav-bar Button {
    min-width: 12;
    height: 3;
    margin: 0 1 0 0;
    border: none;
    background: $surface-darken-1;
    color: $text-muted;
}

#nav-bar Button:hover {
    background: $primary-darken-1;
    color: $text;
}

#nav-bar Button.-primary {
    background: $primary;
    color: $text;
    text-style: bold;
}

#main-scroll {
    height: 1fr;
}

/* ── Urgent ── */
#urgent {
    height: auto;
    max-height: 3;
}

/* ── Header ── */
#header {
    height: auto;
    max-height: 7;
}

/* ── Account Capacity (toggle with 'a') ── */
#account-capacity {
    height: auto;
    max-height: 6;
}

/* ── Active Sessions (interactive DataTable — Enter/f to focus terminal) ── */
#active-sessions {
    height: auto;
    border: solid cyan;
    border-title-color: white;
    border-title-style: bold;
}

#active-sessions:focus {
    border: tall $accent;
}

/* ── Session History (Call History merged in) ── */
#session-history {
    width: 1fr;
    height: 1fr;
    min-height: 14;
    border: solid dodgerblue;
    border-title-color: white;
    border-title-style: bold;
}

#session-history:focus {
    border: tall $accent;
}

/* ── Stats row (Tool Frequency + Skills side by side) ── */
#feed-row {
    layout: horizontal;
    height: auto;
    max-height: 14;
}

#tool-freq {
    width: 1fr;
    height: auto;
    max-height: 14;
}

#skills {
    width: 1fr;
    height: auto;
    max-height: 14;
}

/* ── Passive Drain (shrunk) ── */
#drain {
    height: auto;
    max-height: 10;
}

/* ── Burndown chart ── */
#burndown {
    height: auto;
    max-height: 12;
}

/* ── Search input ── */
#search-input {
    height: auto;
    max-height: 3;
    margin: 0 1;
    border: solid cyan;
}

/* ── System Health ── */
#system-health {
    height: auto;
}

/* ── Drill-down screen ── */
#drilldown-header {
    height: auto;
    max-height: 2;
    padding: 0 1;
}

#accomplishments-view {
    height: 1fr;
    padding: 1 2;
    overflow-y: auto;
}

#drilldown-table {
    height: 1fr;
    border: solid dodgerblue;
}

/* ── Usage metrics screen ── */
#metrics-header {
    height: auto;
    max-height: 2;
    padding: 0 1;
}

#metrics-table {
    height: 1fr;
    border: solid cyan;
}

#metrics-summary {
    height: auto;
    max-height: 3;
    padding: 0 1;
}

/* ── Window Scores (Usage Metrics screen) ── */
#scores-header {
    height: auto;
    max-height: 2;
    padding: 0 1;
}

#scores-table {
    height: 1fr;
    border: solid yellow;
    border-title-color: white;
}

/* ── DataTable styling ── */
DataTable {
    scrollbar-size: 1 1;
}

DataTable > .datatable--header {
    text-style: bold;
}

/* ── Session Tasks screen ── */
#stasks-header {
    height: auto;
    max-height: 2;
    padding: 0 1;
}

#stasks-table {
    height: 1fr;
    border: solid green;
    border-title-color: white;
}

/* ── Project Board screen ── */
#pboard-header {
    height: auto;
    max-height: 2;
    padding: 0 1;
}

#pboard-summary {
    width: 1fr;
    height: auto;
    max-height: 12;
    padding: 0 1;
}

#pboard-table {
    width: 1fr;
    height: 1fr;
    border: solid yellow;
    border-title-color: white;
}

/* ── Account Capacity screen ── */
#cap-header {
    height: auto;
    max-height: 2;
    padding: 0 1;
}

#cap-panels {
    layout: horizontal;
    height: 1fr;
}

#cap-panel-a, #cap-panel-b, #cap-panel-c {
    width: 1fr;
    height: auto;
    padding: 0 1;
}

#cap-footer {
    height: auto;
    max-height: 2;
    padding: 0 1;
}
